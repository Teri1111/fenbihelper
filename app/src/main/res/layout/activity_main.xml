<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:fillViewport="true">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:padding="20dp">

		<TextView
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="@string/page_title"
			android:textAppearance="@style/TextAppearance.MaterialComponents.Headline5"
			android:textStyle="bold" />

		<TextView
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="8dp"
			android:text="@string/page_subtitle"
			android:textAppearance="@style/TextAppearance.MaterialComponents.Body1" />

		<TextView
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="24dp"
			android:text="@string/section_common_actions"
			android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
			android:textStyle="bold" />

		<Button
			android:id="@+id/requestCapturePermissionButton"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:text="@string/action_request_capture_permission" />

		<Button
			android:id="@+id/toggleServiceButton"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:text="@string/action_start_service" />

		<TextView
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="24dp"
			android:text="@string/section_permissions"
			android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
			android:textStyle="bold" />

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:orientation="vertical">

			<LinearLayout
				android:id="@+id/overlayStatusRow"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal">

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/label_overlay_status" />

				<TextView
					android:id="@+id/overlayStatusValue"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/status_unknown"
					android:textStyle="bold" />
			</LinearLayout>

			<LinearLayout
				android:id="@+id/notificationStatusRow"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:orientation="horizontal">

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/label_notification_status" />

				<TextView
					android:id="@+id/notificationStatusValue"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/status_unknown"
					android:textStyle="bold" />
			</LinearLayout>

			<LinearLayout
				android:id="@+id/autoSendStatusRow"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:orientation="horizontal">

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/label_guard_status" />

				<TextView
					android:id="@+id/guardStatusValue"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/status_unknown"
					android:textStyle="bold" />
			</LinearLayout>

			<LinearLayout
				android:id="@+id/shizukuStatusRow"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:orientation="horizontal">

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/label_shizuku_status" />

				<TextView
					android:id="@+id/shizukuStatusValue"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/status_unknown"
					android:textStyle="bold" />
			</LinearLayout>

			<LinearLayout
				android:id="@+id/captureStatusRow"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:orientation="horizontal">

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/label_auto_send_status" />

				<TextView
					android:id="@+id/autoSendStatusValue"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/status_unknown"
					android:textStyle="bold" />
			</LinearLayout>

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:orientation="horizontal">

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/label_capture_status" />

				<TextView
					android:id="@+id/captureStatusValue"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/status_unknown"
					android:textStyle="bold" />
			</LinearLayout>

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:orientation="horizontal">

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/label_service_status" />

				<TextView
					android:id="@+id/serviceStatusValue"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/status_unknown"
					android:textStyle="bold" />
			</LinearLayout>

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:orientation="horizontal">

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="@string/label_last_grant" />

				<TextView
					android:id="@+id/lastGrantValue"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/status_unknown"
					android:textStyle="bold" />
			</LinearLayout>
		</LinearLayout>

		<Button
			android:id="@+id/openOverlayPermissionButton"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="24dp"
			android:text="@string/action_open_overlay_permission" />

		<Button
			android:id="@+id/openAccessibilityServiceButton"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:text="@string/action_open_accessibility_service" />

		<Button
			android:id="@+id/requestShizukuPermissionButton"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:text="@string/action_request_shizuku_permission" />

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:gravity="center_vertical"
			android:orientation="horizontal">

			<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="@string/action_toggle_guard" />

			<Switch
				android:id="@+id/accessibilityGuardSwitch"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content" />
		</LinearLayout>

		<Button
			android:id="@+id/requestNotificationButton"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:text="@string/action_request_notification_permission" />

		<Button
			android:id="@+id/clearCapturePermissionButton"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:text="@string/action_clear_capture_permission" />

		<View
			android:layout_width="match_parent"
			android:layout_height="12dp" />

	</LinearLayout>
</ScrollView>

